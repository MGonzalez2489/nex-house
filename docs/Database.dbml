Table Neighborhood {
  id integer [primary key]
  publicId GUID [not null]
  name text [not null]
  isActive bool [not null]
  createdAt datetime [not null]
  createdBy integer
  updatedAt datetime [not null]
  updatedBy integer
  deletedAt datetime
  deletedBy integer

  Indexes {
    publicId [unique]
  }
}
Table Neigh_Street {
  id integer [primary key]
  publicId GUID [not null]
  name text [not null]
  neighborhoodId integer [not null]
  createdAt datetime [not null]
  createdBy integer
  updatedAt datetime [not null]
  updatedBy integer
  deletedAt datetime
  deletedBy integer

  Indexes {
    publicId [unique]
  }
}
//Users
Table User {
  id integer [primary key]
  publicId GUID [not null]
  firstName text
  lastName text
  email text [unique, not null]
  phone text
  password text [not null]
  roleId integer [not null]
  statusId integer [not null]
  createdAt datetime [not null]
  createdBy integer
  updatedAt datetime [not null]
  updatedBy integer
  deletedAt datetime
  deletedBy integer

  Indexes {
    publicId [unique]
  }
}

Table UserRole {
  id integer [primary key]
  publicId GUID [not null]
  name text 
  displayName text

  Indexes {
    publicId [unique]
  }
}
Table UserStatus {
  id integer [primary key]
  publicId GUID [not null]
  name text
  displayName text

  Indexes {
    publicId [unique]
  }
}
//units
Table Unit {
  id integer [primary key]
  publicId GUID [not null]
  streetId integer [not null]
  typeId integer [not null]
  statusId integer [not null]
  identifier text [not null]
  createdAt datetime [not null]
  createdBy integer
  updatedAt datetime [not null]
  updatedBy integer
  deletedAt datetime
  deletedBy integer

  Indexes {
    publicId [unique]
  }
}
Table UnitType {
  id integer [primary key]
  publicId GUID [not null]
  name text
  displayName text

  Indexes {
    publicId [unique]
  }
}
Table UnitStatus {
  id integer [primary key]
  publicId GUID [not null]
  name text
  displayName text

  Indexes {
    publicId [unique]
  }
}

Table UserUnit{
   id integer [primary key]
  publicId GUID [not null]
   userId integer [not null]
   unitId integer [not null]
   roleId integer [not null]
   isCurrentOccupant bool [not null]

    createdAt datetime [not null]
  createdBy integer
  updatedAt datetime [not null]
  updatedBy integer
  deletedAt datetime
  deletedBy integer

   Indexes {
    (userId, unitId, roleId, deletedAt) [unique]
    publicId [unique]

  }
}

Table UserUnitRole {
  id integer [primary key]
  publicId GUID [not null]
  name text
  displayName text

  Indexes {
    publicId [unique]
  }
}
//// Finance
Table Fee {
  id integer [primary key]
  publicId GUID [not null]
  neighId integer [not null]
  ////basic
  name text [not null]
  description text
  amount integer
  type text [not null]
  ////schedule
  cronSchedule text
  cronDescription text
  startDate datetime
  endDate datetime
  lastExecutionDate datetime
  //
  statusId integer [not null]

  createdAt datetime [not null]
  createdBy integer
  updatedAt datetime [not null]
  updatedBy integer
  deletedAt datetime
  deletedBy integer

  Indexes {
    publicId [unique]
  }
}

Table FeeStatus{
  id integer [primary key]
  publicId GUID [not null]

  name text
  displayName text

  Indexes {
    publicId [unique]
  }
}

Table Charge {
  id integer [primary key]
  publicId GUID [not null]
  feeId integer [not null]
  unitId integer [not null]
  amount integer [not null]
  statusId integer [not null]
  dueDate datetime [not null]
  cancelationReason text
  canceledBy integer

  createdAt datetime [not null]
  createdBy integer
  updatedAt datetime [not null]
  updatedBy integer
  deletedAt datetime
  deletedBy integer

  Indexes {
    publicId [unique]
  }
}

Table ChargeStatus {
  id integer [primary key]
  publicId GUID [not null]
  name text [not null]
  displayName text [not null]

  Indexes {
    publicId [unique]
  }
}

Table Payment{
  id integer [primary key]
  publicId GUID [not null]

  chargeId integer [not null]
  amount integer [not null]
  evidenceId integer
  statusId integer [not null]
  paymentDate datetime [not null]
  userId integer [not null]
  adminNotes text

  createdAt datetime [not null]
  createdBy integer
  updatedAt datetime [not null]
  updatedBy integer
  deletedAt datetime
  deletedBy integer

  Indexes {
    publicId [unique]
  }
}

Table PaymentStatus {
  id integer [primary key]
  publicId GUID [not null]
  name text [not null]
  displayName text [not null]

  Indexes {
    publicId [unique]
  }
}

Table Transactions {
  id integer [primary key]
  publicId GUID [not null]

  
  neighId integer [not null]
  typeId integer [not null]
  sourceTypeId integer [not null]
  evidenceId integer
  reversedById integer
  categoryId integer [not null]
  paymentId integer
 
  amount integer [not null]
  transactionDate datetime [not null]
  name text [not null]
  description text

  createdAt datetime [not null]
  createdBy integer
  updatedAt datetime [not null]
  updatedBy integer
  deletedAt datetime
  deletedBy integer


  Indexes {
    publicId [unique]
  }
}

Table TransactionCategory {
  id integer [primary key]
  publicId GUID [not null]
  neighId integer [not null]

  name text [not null]
  displayName text [not null]
  icon text [not null]
  color text [not null]
  forTransactionTypeId integer [not null]

  updatedAt datetime [not null]
  updatedBy integer

  Indexes {
    publicId [unique]
  }
}

Table TransactionType {
  id integer [primary key]
  publicId GUID [not null]

  name text 
  displayName text

  Indexes {
    publicId [unique]
  }
}

Table TransactionSource {
  id integer [primary key]
  publicId GUID [not null]

  name text 
  displayName text

  Indexes {
    publicId [unique]
  }
}

// Others
Table File {
  id integer [primary key]
  publicId GUID [not null]

  originalName text [not null]
  fileName text [not null]
  mimeType text [not null]
  size bigint [not null]
  url text [not null]
  extension text 

  createdAt datetime [not null]
  createdBy integer
  updatedAt datetime [not null]
  updatedBy integer
  deletedAt datetime
  deletedBy integer


  Indexes {
    publicId [unique]
  }
}


//relationships
Ref neigh_streets: Neigh_Street.neighborhoodId > Neighborhood.id
Ref role_user: User.roleId > UserRole.id
Ref status_user: User.statusId > UserStatus.id

Ref unit_type: Unit.typeId > UnitType.id
Ref unit_status: Unit.statusId > UnitStatus.id
Ref unit_street: Unit.streetId > Neigh_Street.id

Ref userunit_user: User.id < UserUnit.userId
Ref userunit_unit: Unit.id < UserUnit.unitId
Ref userunit_role: UserUnitRole.id < UserUnit.roleId

Ref neigh_created: Neighborhood.createdBy > User.id
Ref neigh_updated: Neighborhood.updatedBy > User.id
Ref neigh_deleted: Neighborhood.deletedBy > User.id

Ref street_created: Neigh_Street.createdBy > User.id
Ref street_updated: Neigh_Street.updatedBy > User.id
Ref street_deleted: Neigh_Street.deletedBy > User.id

Ref user_created: User.createdBy > User.id
Ref user_updated: User.updatedBy > User.id
Ref user_deleted: User.deletedBy > User.id

Ref unit_created: Unit.createdBy > User.id
Ref unit_updated: Unit.updatedBy > User.id
Ref unit_deleted: Unit.deletedBy > User.id

Ref userunit_created: UserUnit.createdBy > User.id
Ref userunit_updated: UserUnit.updatedBy > User.id
Ref userunit_deleted: UserUnit.deletedBy > User.id

Ref fee_neigh: Fee.neighId > Neighborhood.id
Ref fee_status: FeeStatus.id < Fee.statusId
Ref fee_charge: Charge.feeId < Fee.id
Ref charge_unit: Charge.unitId > Unit.id
Ref charge_status: Charge.statusId > ChargeStatus.id
Ref paymen_status: Payment.statusId > PaymentStatus.id
Ref payment_charge: Payment.chargeId > Charge.id

Ref payment_user: Payment.userId > User.id              // Quién reportó el pago
Ref charge_canceled_user: Charge.canceledBy > User.id   // Admin que canceló el cargo

Ref fee_created: Fee.createdBy > User.id
Ref fee_updated: Fee.updatedBy > User.id
Ref fee_deleted: Fee.deletedBy > User.id

Ref charge_created: Charge.createdBy > User.id
Ref charge_updated: Charge.updatedBy > User.id
Ref charge_deleted: Charge.deletedBy > User.id

Ref payment_created: Payment.createdBy > User.id
Ref payment_updated: Payment.updatedBy > User.id
Ref payment_deleted: Payment.deletedBy > User.id

Ref trans_created: Transactions.createdBy > User.id
Ref trans_updated: Transactions.updatedBy > User.id
Ref trans_deleted: Transactions.deletedBy > User.id

Ref file_created: File.createdBy > User.id
Ref file_updated: File.updatedBy > User.id
Ref file_deleted: File.deletedBy > User.id

Ref trans_neigh: Transactions.neighId > Neighborhood.id
Ref: Transactions.paymentId > Payment.id
Ref trans_type: Transactions.typeId > TransactionType.id
Ref trans_source: Transactions.sourceTypeId > TransactionSource.id
Ref trans_cat: Transactions.categoryId > TransactionCategory.id
Ref trans_rev: Transactions.id < Transactions.reversedById
Ref cat_trans_type: TransactionCategory.forTransactionTypeId > TransactionType.id
Ref transcat_updated: TransactionCategory.updatedBy > User.id

Ref trans_file: Transactions.evidenceId < File.id
Ref pay_file: Payment.evidenceId < File.id

//data
Records UserRole(id, name, displayName){
  1,'root','ROOT'
  2,'admin','Administrador'
  3,'resident','Residente'
}
Records UserStatus(id, name, displayName){
  1,'active','Activo'
  2,'inactive','Inactivo'
  3,'pending-completion','Pendiente'
}
Records UnitStatus(id, name, displayName){
  1,'occupied','Ocupado'
  2,'vacant','Sin habitar'
  3,'rented','En renta'
}
Records UnitType(id, name, displayName){
  1,'house','Casa'
  2,'apartment','Departamento'
}
Records UserUnitRole(id, name, displayName){
  1,'owner','Dueño'
  2,'family','Familiar'
  3,'tenant','Inquilino'
}

Records FeeStatus(id,  name, displayName){
  1,'active','Activo'
  2,'paused','En pausa'
  3,'cancelled','Cancelado'
  4,'scheduled','Agendado'
  5,'completed','Completado'
}

Records ChargeStatus(id, name, displayName){
1,'pending','Pendiente'
2,'in_review','En revisión'
3,'paid','Pagado'
4,'cancelled','Cancelado'
}

Records PaymentStatus(id, name, displayName){
1,'pending','Pendiente'
2,'approved','Aprobado'
3, 'rejected','Rechazado'
4, 'canceled','Cancelado'
}

Records TransactionCategory(id, name, displayName, icon, color, forTransactionTypeId){
1,'maintenance','Mantenimiento','maintenance','#10b981',1
2,'utilities','Servicios Públicos','utilities','#f59e0b',2
3,'repairs','Reparaciones y Mejoras','repairs','#3b82f6',2
4,'security','Seguridad','security','#ef4444',2
5,'events','Eventos y Amenidades','events','#8b5cf6',2
}

Records TransactionSource(id, name, displayName){
1,'payment','Pago'
2,'direct','Directo'
}
Records TransactionType(id, name, displayName){
1,'income','Ingreso'
2,'expense','Gasto'
}
